# Copy to .env for local testing. Never commit real keys or a real .env.
#
# ─────────────────────────────────────────────────────────────────────────────
# Hospital Edition backend (hospital/, FastAPI)  —  pydantic-settings reads .env
# ─────────────────────────────────────────────────────────────────────────────

# Database — SQLite for the MVP pilot; PostgreSQL in production.
DATABASE_URL=sqlite+aiosqlite:///./hospital.db

# Knowledge base content root.
KB_ROOT=knowledge_base/hosted/content

# JWT session signing — MUST be a strong unique value in production.
JWT_SECRET=dev-secret-CHANGE-IN-PROD
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480
JWT_ADMIN_EXPIRE_MINUTES=240

# Google OAuth (clinician sign-in).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# First admin account bootstrapped on startup (email must match a Google login).
BOOTSTRAP_ADMIN_EMAIL=

# Audit-log MRN hashing salt — MUST be a strong unique value in production.
AUDIT_MRN_SALT=dev-salt-CHANGE-IN-PROD

# CORS — comma-separated list of allowed frontend origins.
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173

# HIS webhook HMAC secret (hospital information system integration).
HIS_WEBHOOK_SECRET=

# PWA Web Push (VAPID) — generate a keypair for production.
VAPID_PRIVATE_KEY=
VAPID_PUBLIC_KEY=
VAPID_SUBJECT=mailto:admin@openonco.local

# LLM — extraction/translation ONLY (CHARTER §8.3: never picks regimens).
ANTHROPIC_API_KEY=
EXTRACTION_MODEL=claude-sonnet-4-6

# ─────────────────────────────────────────────────────────────────────────────
# Public static-site "ask" prototype (docs/ask.html backend)  —  separate from
# the hospital app above. Only needed if you run that prototype.
# ─────────────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-replace-with-openonco-project-key
OPENAI_MODEL=gpt-5.2
OPENONCO_ALLOWED_ORIGIN=https://openonco.info
# OPENONCO_DEBUG=1
