# ============================================================
# OpenOnco Hospital Edition — environment variables
# Copy to .env for local development.  NEVER commit real keys.
# All defaults are safe for local dev; change starred (*) items
# before any production deployment.
# ============================================================

# ── Database ─────────────────────────────────────────────────
# SQLite (dev / test):
DATABASE_URL=sqlite+aiosqlite:///./hospital.db
# PostgreSQL (production):
# DATABASE_URL=postgresql+asyncpg://openonco:password@db:5432/openonco

# ── Knowledge base ────────────────────────────────────────────
KB_ROOT=knowledge_base/hosted/content

# ── JWT  (*) ─────────────────────────────────────────────────
JWT_SECRET=dev-secret-CHANGE-IN-PROD
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480
JWT_ADMIN_EXPIRE_MINUTES=240

# ── Google OAuth  (*) ─────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Redirect URI must be registered in Google Cloud Console:
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# ── Bootstrap admin  (*) ─────────────────────────────────────
# First user with this email is promoted to kb_admin on login.
BOOTSTRAP_ADMIN_EMAIL=

# ── Audit  (*) ───────────────────────────────────────────────
AUDIT_MRN_SALT=dev-salt-CHANGE-IN-PROD

# ── CORS ─────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173

# ── Request size limit ────────────────────────────────────────
MAX_BODY_SIZE_BYTES=1048576

# ── Rate limiting ─────────────────────────────────────────────
RATE_LIMIT_LOGIN=20/minute
RATE_LIMIT_HIS_WEBHOOK=100/minute

# ── HIS webhook  (*) ─────────────────────────────────────────
# Shared HMAC-SHA256 secret between HIS system and this portal.
HIS_WEBHOOK_SECRET=

# ── KB crawler webhook  (*) ──────────────────────────────────
CRAWLER_WEBHOOK_SECRET=

# ── LLM extraction (CHARTER §8.3 — extraction only) ─────────
ANTHROPIC_API_KEY=
EXTRACTION_MODEL=claude-sonnet-4-6

# ── PWA push notifications / VAPID ───────────────────────────
# Generate with: python -c "from pywebpush import Vapid; v=Vapid(); v.generate_keys(); print(v.private_key, v.public_key)"
VAPID_PRIVATE_KEY=
VAPID_PUBLIC_KEY=
VAPID_SUBJECT=mailto:admin@yourhospital.example

# ── LINE Notify ───────────────────────────────────────────────
# Set LINE_NOTIFY_ENABLED=true to send LINE push messages for high-urgency reminders.
# Each HCP registers their own personal access token via PUT /api/v1/me/line-notify-token.
# Obtain tokens at: https://notify-bot.line.me/my/
LINE_NOTIFY_ENABLED=false

# ── FHIR TW Core ─────────────────────────────────────────────
# POST /api/v1/fhir/Patient/$import accepts FHIR R4 Patient resources (TW Core profile).
# No additional environment variables required — the endpoint is enabled by default.

# ── Local dev login (SQLite only — NEVER enable in production) ───────────────
# When true, POST /auth/dev/login accepts {email, role} and issues a cookie
# without requiring Google OAuth.  Only active when DATABASE_URL is SQLite.
# Run `python scripts/seed_dev_users.py` (or `make seed`) after enabling.
DEV_LOCAL_LOGIN=false

# ── Backend feature flags ─────────────────────────────────────
# Set any of these to false to disable the corresponding module.
FEATURE_FHIR_IMPORT=true
FEATURE_TRIALS_SEARCH=true
FEATURE_PDF_EXPORT=true
FEATURE_LINE_NOTIFY_API=true
FEATURE_CIVIC_LOOKUP=false

# ── Frontend feature flags (prefix: VITE_) ────────────────────
# Mirror of the backend flags. Set in frontend/.env (not this file).
# VITE_FEATURE_FHIR_IMPORT=true
# VITE_FEATURE_TRIALS_SEARCH=true
# VITE_FEATURE_PDF_EXPORT=true
# VITE_FEATURE_LINE_NOTIFY_API=true
# VITE_FEATURE_CIVIC_LOOKUP=false
